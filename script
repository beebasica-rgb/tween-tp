-- ============================================================
-- PUBLIC SERVER HOPPER - sin GUI, fuerza servidor publico
-- Obtiene la lista real de servers publicos via API de Roblox
-- y teleporta usando TeleportToPlaceInstance con un JobId publico.
-- ============================================================

if not game:IsLoaded() then game.Loaded:Wait() end

-- ── 1. SERVICIOS Y JUGADOR ───────────────────────────────────
local Players         = game:GetService("Players")
local TeleportService = game:GetService("TeleportService")
local HttpService     = game:GetService("HttpService")

local LocalPlayer = Players.LocalPlayer
if not LocalPlayer then
    Players.PlayerAdded:Wait()
    LocalPlayer = Players.LocalPlayer
end
if not LocalPlayer.Character then
    LocalPlayer.CharacterAdded:Wait()
end

-- ── 3. OBTENER SERVIDORES PUBLICOS VIA API DE ROBLOX ────────
-- Usa la funcion HTTP del executor (request / syn.request / http.request)
local function httpGet(url)
    local response

    -- Detectar que funcion HTTP tiene el executor
    if typeof(request) == "function" then
        response = request({ Url = url, Method = "GET" })
    elseif typeof(http) == "table" and typeof(http.request) == "function" then
        response = http.request({ Url = url, Method = "GET" })
    elseif typeof(syn) == "table" and typeof(syn.request) == "function" then
        response = syn.request({ Url = url, Method = "GET" })
    elseif typeof(fluxus) == "table" and typeof(fluxus.request) == "function" then
        response = fluxus.request({ Url = url, Method = "GET" })
    else
        error("No se encontro funcion HTTP en el executor")
    end

    if not response or response.StatusCode ~= 200 then
        return nil
    end
    return response.Body
end

local function getPublicServers(placeId, cursor)
    local url = string.format(
        "https://games.roblox.com/v1/games/%d/servers/Public?sortOrder=Asc&excludeFullGames=false&limit=100",
        placeId
    )
    if cursor and cursor ~= "" then
        url = url .. "&cursor=" .. cursor
    end

    local ok, body = pcall(httpGet, url)
    if not ok or not body then
        warn("[HOP] Error HTTP: " .. tostring(body))
        return nil, nil
    end

    local ok2, data = pcall(function() return HttpService:JSONDecode(body) end)
    if not ok2 or not data or not data.data then
        warn("[HOP] Error al parsear JSON")
        return nil, nil
    end

    return data.data, data.nextPageCursor
end

-- ── 4. TELEPORT A UN SERVER PUBLICO ─────────────────────────
local placeId       = game.PlaceId
local currentJobId  = game.JobId

print("[HOP] Buscando servidores publicos para PlaceId: " .. placeId)
print("[HOP] Server actual (privado): " .. currentJobId)

task.wait(1)

local function hop()
    local cursor = nil
    local intentos = 0

    repeat
        local servers, nextCursor = getPublicServers(placeId, cursor)
        cursor = nextCursor

        if not servers then
            warn("[HOP] No se pudo obtener lista, reintentando en 2s...")
            task.wait(2)
            cursor = nil
            continue
        end

        for _, server in ipairs(servers) do
            -- Saltar el server actual y servers vacios
            if server.id == currentJobId then continue end
            if (server.playing or 0) < 1 then continue end

            intentos += 1
            print(string.format("[HOP] Intentando server publico #%d (jugadores: %d, id: %s)",
                intentos, server.playing, server.id))

            -- BindableEvent para despertar el hilo INSTANTANEO al fallar,
            -- sin ningun polling. Si el teleport es exitoso el juego carga
            -- otro servidor y este script muere solo.
            local signal    = Instance.new("BindableEvent")
            local failResult = nil
            local conn

            conn = TeleportService.TeleportInitFailed:Connect(function(player, result)
                failResult = result
                conn:Disconnect()
                signal:Fire()  -- despierta el hilo al instante
            end)

            -- Timeout de seguridad: 20s sin respuesta = exito real
            local timeoutThread = task.delay(20, function()
                if signal.Parent then  -- si aun no fue destruido
                    signal:Fire()
                end
            end)

            local ok, callErr = pcall(function()
                TeleportService:TeleportToPlaceInstance(placeId, server.id, LocalPlayer)
            end)

            if not ok then
                task.cancel(timeoutThread)
                conn:Disconnect()
                signal:Destroy()
                warn("[HOP] Error al llamar teleport: " .. tostring(callErr))
            else
                print("[HOP] Teleport enviado...")
                signal.Event:Wait()  -- bloquea hasta fallo O timeout, sin polling
                task.cancel(timeoutThread)
                signal:Destroy()

                if failResult then
                    warn("[HOP] Fallo (" .. tostring(failResult) .. "), siguiente server...")
                    -- failResult != nil → continua el for al siguiente server
                else
                    -- Sin fallo en 20s = el juego ya cambio de servidor
                    warn("[HOP] Sin respuesta en 20s, probando siguiente...")
                end
            end
        end

        -- Si se acabaron los servers en esta pagina y no hay mas
        if not cursor or cursor == "" then
            print("[HOP] Se revisaron todos los servers disponibles, reiniciando busqueda...")
            task.wait(3)
            cursor = nil
        end

    until false
end

hop()
